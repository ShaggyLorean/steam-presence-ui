<Page x:Class="SteamPresenceUI.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Dashboard">

    <Grid>
        <Grid x:Name="MainContentGrid" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Dashboard" FontSize="28" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,16"/>
            <ui:InfoBar x:Name="MandatoryLoginInfoBar" Title="MANDATORY LOGIN" Message="PLEASE LOG-IN TO STEAMCOMMUNITY.COM IN ORDER TO GATHER THE COOKIES." Severity="Warning" IsOpen="True" IsClosable="False" Margin="0,0,0,16"/>

            <ui:CardControl Grid.Row="1" Margin="0,0,0,16" Icon="{ui:SymbolIcon Play24}">
                <ui:CardControl.Header>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Steam Presence Engine" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" x:Name="EngineStatusText" Text="Stopped" Foreground="Gray" FontSize="12"/>
                    </Grid>
                </ui:CardControl.Header>
                <StackPanel Orientation="Horizontal">
                    <ui:ProgressRing x:Name="RunningSpinner" IsIndeterminate="True" Visibility="Collapsed" Width="24" Height="24" Margin="0,0,16,0" />
                    <ui:Button x:Name="StartStopButton" Content="Start Engine" Appearance="Primary" Icon="{ui:SymbolIcon Play24}" Click="StartStopButton_Click"/>
                </StackPanel>
            </ui:CardControl>

            <ui:CardExpander Grid.Row="2" Header="Live Console Logs" Icon="{ui:SymbolIcon DocumentText24}" IsExpanded="True" VerticalAlignment="Stretch">
                <TextBox x:Name="LogTextBox"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         MinHeight="200"
                         Height="Auto"/>
            </ui:CardExpander>
        </Grid>

        <Grid x:Name="CookieProtectionOverlay" Visibility="Collapsed">
            <Border Background="#CC000000" CornerRadius="8" Margin="12"/>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="500">
                <ui:SymbolIcon Symbol="ShieldLock24" FontSize="64" Foreground="#FFD700" Margin="0,0,0,24"/>
                <TextBlock Text="Action Required: Cookies Missing" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="Please head to the Cookies tab to set up your session. You must provide a 'cookies.txt' file in the application folder to enable the engine. If you don't know how, the Cookies tab contains step-by-step instructions." 
                           TextWrapping="Wrap" Foreground="#CCCCCC" TextAlignment="Center" FontSize="14" Margin="0,0,0,32"/>
                <ui:Button Content="Go to Cookies Tab" Appearance="Primary" Icon="{ui:SymbolIcon Document24}" Click="GoToCookies_Click" HorizontalAlignment="Center" Padding="24,12"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
